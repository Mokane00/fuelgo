PORT=5001
DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=fuelgo_db
JWT_SECRET=change_this_to_a_random_string
JWT_EXPIRES_IN=8h
NODE_ENV=production
FRONTEND_URL=https://your-app.railway.app

# ── Google Maps ───────────────────────────────────
GOOGLE_MAPS_KEY=

# ── Stripe ───────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# ── Google OAuth2 ────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-app.railway.app/api/auth/google/callback

# ── Gmail SMTP ───────────────────────────────────
SMTP_USER=
SMTP_PASS=

# ── Cloudinary ───────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Firebase FCM ─────────────────────────────────
# On Railway: paste the entire firebase-adminsdk.json content as one line below
FIREBASE_SERVICE_ACCOUNT_JSON=
# Local dev only (file path fallback):
FIREBASE_CREDENTIAL_PATH=./firebase-adminsdk.json

# ── SendGrid ─────────────────────────────────────
SENDGRID_API_KEY=

# ── Open Exchange Rates ───────────────────────────
EXCHANGE_RATES_APP_ID=

# ── OpenWeatherMap ────────────────────────────────
OPENWEATHER_API_KEY=

# ── M-Pesa (Daraja) ──────────────────────────────
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://your-app.railway.app/api/payments/mpesa/callback
MPESA_ENV=sandbox

# ── What3Words ────────────────────────────────────
W3W_API_KEY=

# ── Mapbox ───────────────────────────────────────
MAPBOX_ACCESS_TOKEN=

# ── Carbon Interface ──────────────────────────────
CARBON_INTERFACE_API_KEY=
